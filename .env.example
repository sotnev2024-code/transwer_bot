# ════════════════════════════════════════════════════════════════
#  Общий конфиг для обоих ботов: Telegram + MAX
#  Скопируйте в .env и заполните своими значениями.
# ════════════════════════════════════════════════════════════════

# ─── Telegram-бот ─────────────────────────────────────────────
# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ID Telegram-чата менеджера (куда идут ВСЕ заявки — и из Telegram, и из MAX)
# Чтобы узнать свой chat_id — напишите @userinfobot
MANAGER_CHAT_ID=123456789

# ID администраторов Telegram-бота через запятую (доступ к /admin)
ADMIN_IDS=123456789

# ─── MAX messenger бот ────────────────────────────────────────
# Токен MAX-бота (получить через BotFather MAX)
MAX_BOT_TOKEN=your_max_bot_token_here

# (опционально) user-id админов в MAX — пока не используется,
# admin-панель доступна только в Telegram
MAX_ADMIN_IDS=

# ─── Общее ────────────────────────────────────────────────────
# Путь к БД. Оставьте пустым — будет transfer_bot.db в корне проекта.
# Для продакшена можно указать абсолютный путь, например /opt/transfer_bot/transfer_bot.db
DB_PATH=
